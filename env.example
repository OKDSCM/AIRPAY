import { clsx, type ClassValue } from 'clsx';
import { twMerge } from 'tailwind-merge';

// --- Utility ---
function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}

// --- Types ---
type TierType = 'base' | 'accessory';

interface AirTier {
  id: string;
  name: string;
  price: number;
  type: TierType;
  description: string;
  theme: {
    primary: string;
    secondary: string;
    accent: string;
    bg: string;
    text: string;
    pattern?: string;
  };
  logo: React.ReactNode;
  rarity: 'Common' | 'Rare' | 'Epic' | 'Legendary' | 'Godly';
}

interface UserAccount {
  name: string;
  balance: number;
  subscriptions: string[]; // IDs of tiers
  joinedDate: string;
  isGodly: boolean;
}

