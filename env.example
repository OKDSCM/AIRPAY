            <h4 className="font-bold mb-4 uppercase text-xs tracking-widest text-zinc-500">Support</h4>
            <ul className="space-y-2 text-sm text-zinc-400">
              <li><a href="#" className="hover:text-white transition-colors">Help Center</a></li>
              <li><a href="#" className="hover:text-white transition-colors">Report Air Leak</a></li>
              <li><a href="#" className="hover:text-white transition-colors">Contact Sales</a></li>
            </ul>
          </div>
        </div>
        <div className="max-w-7xl mx-auto mt-20 pt-8 border-t border-zinc-800 flex flex-col md:flex-row justify-between gap-4 text-xs text-zinc-500">
          <p>© 2026 AirPay+ Satirical Systems. All rights reserved.</p>
          <div className="flex gap-6">
            <a href="#" className="hover:text-white">Privacy Policy</a>
            <a href="#" className="hover:text-white">Terms of Breathing</a>
            <a href="#" className="hover:text-white">Cookie Settings</a>
          </div>
        </div>
      </footer>

      {/* Modals & Overlays */}
      <AnimatePresence>
        {isWatchingAd && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 z-[100] bg-black flex items-center justify-center p-6"
          >
            <div className="text-center text-white max-w-lg w-full">
              <div className="aspect-video bg-zinc-800 rounded-3xl mb-8 flex items-center justify-center relative overflow-hidden">
                <motion.div 
                  initial={{ width: "100%" }}
                  animate={{ width: "0%" }}
                  transition={{ duration: 5, ease: "linear" }}
                  className="absolute bottom-0 left-0 h-2 bg-indigo-600 z-10"
                />
                <div className="flex flex-col items-center gap-4">
                  <Zap size={48} className="text-indigo-500 animate-pulse" />
                  <p className="text-xl font-bold">ADVERTISEMENT IN PROGRESS</p>
                  <p className="text-zinc-400 text-sm">Do not close. Your lungs depend on it.</p>
                </div>
              </div>
              <p className="text-zinc-500 text-xs uppercase tracking-widest">Sponsored by GlobalAtmosphere Corp</p>
            </div>
          </motion.div>
        )}

        {showDashboard && (
          <>
            <motion.div 
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              onClick={() => setShowDashboard(false)}
              className="fixed inset-0 z-50 bg-black/40 backdrop-blur-sm"
            />
            <motion.div 
              initial={{ x: "100%" }}
              animate={{ x: 0 }}
              exit={{ x: "100%" }}
              transition={{ type: "spring", damping: 25, stiffness: 200 }}
              className="fixed top-0 right-0 h-full w-full max-w-md bg-white z-50 shadow-2xl flex flex-col"
            >
              <div className="p-8 border-b border-zinc-100 flex justify-between items-center">
                <h3 className="text-2xl font-black tracking-tighter">USER DASHBOARD</h3>
                <button onClick={() => setShowDashboard(false)} className="p-2 rounded-full hover:bg-zinc-100 transition-colors">
                  <X size={24} />
                </button>
              </div>
              
              <div className="flex-1 overflow-y-auto p-8">
                <div className="flex items-center gap-4 mb-8">
                  <div className="w-16 h-16 rounded-2xl bg-indigo-600 flex items-center justify-center text-white">
                    <User size={32} />
                  </div>
                  <div>
                    <input 
                      type="text" 
                      value={user.name || "VALUED BREATHER"} 
                      onChange={(e) => setUser(prev => ({ ...prev, name: e.target.value }))}
                      className="text-xl font-bold bg-transparent border-none focus:ring-0 p-0 w-full"
                      placeholder="Enter your name"
                    />
                    <p className="text-xs text-zinc-400 uppercase font-bold">Member since {user.joinedDate}</p>
                    {user.isGodly && (
                      <div className="flex items-center gap-1 mt-1">
                        <Crown size={12} className="text-yellow-500" />
                        <span className="text-[10px] font-bold text-yellow-600 uppercase">Godly Status Active</span>
                      </div>
                    )}
                  </div>
                </div>

                <div className="grid grid-cols-2 gap-4 mb-8">
                  <div className="p-4 bg-zinc-50 rounded-2xl border border-zinc-100">
                    <span className="text-2xl font-black tracking-tighter text-indigo-600">${user.balance.toFixed(2)}</span>
                    <p className="text-[10px] text-zinc-400 uppercase font-bold mt-1">BreathCredits</p>
                  </div>
                  <div className="p-4 bg-zinc-50 rounded-2xl border border-zinc-100">
                    <span className="text-2xl font-black tracking-tighter">{user.subscriptions.length}</span>
                    <p className="text-[10px] text-zinc-400 uppercase font-bold mt-1">Active Tiers</p>
                  </div>
                </div>

                <div className="mb-8">
                  <h4 className="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-4">Quick Actions</h4>
                  <div className="grid grid-cols-1 gap-3">
                    <button 
                      onClick={() => setShowDeposit(true)}
                      className="w-full flex items-center justify-between p-4 bg-emerald-50 text-emerald-700 rounded-2xl font-bold hover:bg-emerald-100 transition-all group"
                    >
                      <div className="flex items-center gap-3">
                        <CreditCard size={20} />
                        <span>Deposit Credits</span>
                      </div>
                      <Sparkles size={16} className="opacity-0 group-hover:opacity-100 transition-opacity" />
                    </button>
                    {!user.isGodly && (
                      <button 
                        onClick={() => {
                          setGodlyFlowStep(0);
                          setShowGodlyFlow(true);
                        }}
                        className="w-full flex items-center justify-between p-4 bg-yellow-400 text-yellow-900 rounded-2xl font-bold hover:bg-yellow-300 transition-all group"
                      >
                        <div className="flex items-center gap-3">
                          <Crown size={20} />
                          <span>Upgrade to Godly ($999.99)</span>
                        </div>
                        <Zap size={16} className="opacity-0 group-hover:opacity-100 transition-opacity" />
                      </button>
                    )}
                    <button 
                      onClick={handleWatchAd}
                      className="w-full flex items-center justify-between p-4 bg-indigo-50 text-indigo-700 rounded-2xl font-bold hover:bg-indigo-100 transition-all group"
                    >
                      <div className="flex items-center gap-3">
                        <Zap size={20} />
                        <span>Watch Ad (+50 BC)</span>
                      </div>
                      <TrendingUp size={16} className="opacity-0 group-hover:opacity-100 transition-opacity" />
                    </button>
                  </div>
                </div>

                <div>
                  <h4 className="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-4">Your Inventory</h4>
                  <div className="space-y-3">
                    {currentTiers.map(tier => (
                      <div key={tier.id} className="flex items-center justify-between p-4 bg-white border border-zinc-100 rounded-2xl shadow-sm">
                        <div className="flex items-center gap-3">
                          <div className={cn("w-10 h-10 rounded-xl flex items-center justify-center", tier.theme.bg, tier.theme.text)}>
                            {tier.logo}
                          </div>
                          <div>
                            <p className="font-bold text-sm">{tier.name}</p>
                            <p className="text-[10px] text-zinc-400 uppercase">{tier.type}</p>
                          </div>
                        </div>
                        <button 
                          onClick={() => {
                            setSelectedTier(tier);
                            setShowSuccess(true);
                          }}
                          className="p-2 text-zinc-400 hover:text-indigo-600 transition-colors"
                        >
                          <CreditCard size={18} />
                        </button>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
              
              <div className="p-8 border-t border-zinc-100 bg-zinc-50">
                <button 
                  onClick={() => {
                    if (confirm("Are you sure you want to reset your respiratory profile? All subscriptions will be lost.")) {
                      localStorage.removeItem('airpay_user');
                      window.location.reload();
                    }
                  }}
                  className="w-full py-3 text-red-500 text-xs font-bold uppercase tracking-widest hover:bg-red-50 rounded-xl transition-colors"
                >
                  Reset Account Data
                </button>
              </div>
            </motion.div>
          </>
        )}

        {showDeposit && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 z-[60] bg-black/60 backdrop-blur-md flex items-center justify-center p-6"
          >
            <motion.div 
              initial={{ scale: 0.9, y: 20 }}
              animate={{ scale: 1, y: 0 }}
              className="bg-white rounded-[40px] p-10 max-w-md w-full relative"
            >
              <button 
                onClick={() => setShowDeposit(false)}
                className="absolute top-6 right-6 p-2 rounded-full bg-zinc-100 hover:bg-zinc-200 transition-colors"
              >
                <X size={20} />
              </button>
              
              <div className="text-center mb-8">
                <div className="w-16 h-16 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4">
                  <CreditCard size={32} />
                </div>
                <h3 className="text-2xl font-black tracking-tighter">DEPOSIT CREDITS</h3>
                <p className="text-zinc-500 text-sm mt-1">Add funds to your respiratory account.</p>
              </div>

              <form onSubmit={handleDeposit} className="space-y-4">
                <div>
                  <label className="text-[10px] uppercase font-bold text-zinc-400 mb-1 block">Amount ($)</label>
                  <input 
                    type="number" 
                    value={depositAmount}
                    onChange={(e) => setDepositAmount(e.target.value)}
                    className="w-full p-4 bg-zinc-50 border border-zinc-200 rounded-2xl font-mono font-bold text-lg focus:ring-2 focus:ring-indigo-500 outline-none"
                    placeholder="50.00"
                    required
                  />
                </div>
                
                <div className="p-4 bg-zinc-900 rounded-2xl relative overflow-hidden">
                  <div className="flex justify-between items-start mb-6">
                    <div className="w-10 h-6 bg-yellow-500/20 rounded-sm" />
                    <Wind size={16} className="text-white/20" />
                  </div>
                  <div className="space-y-4">
                    <input 
                      type="text" 
                      placeholder="**** **** **** ****" 
                      className="w-full bg-transparent border-none p-0 text-white font-mono tracking-widest focus:ring-0 placeholder:text-white/20"
                      required
                    />
                    <div className="flex gap-4">
                      <input 
                        type="text" 
                        placeholder="MM/YY" 
                        className="w-20 bg-transparent border-none p-0 text-white font-mono text-sm focus:ring-0 placeholder:text-white/20"
                        required
                      />
                      <input 
                        type="text" 
                        placeholder="CVV" 
                        className="w-12 bg-transparent border-none p-0 text-white font-mono text-sm focus:ring-0 placeholder:text-white/20"
                        required
                      />
                    </div>
                  </div>
                </div>

                <button 
                  type="submit"
                  className="w-full py-4 bg-indigo-600 text-white rounded-2xl font-bold hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-200"
                >
                  Secure Deposit
                </button>
                <p className="text-[10px] text-center text-zinc-400 uppercase font-bold">Encrypted by AirPay Secure™</p>
              </form>
            </motion.div>
          </motion.div>
        )}

        {showGodlyFlow && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 z-[70] bg-zinc-950/90 backdrop-blur-2xl flex items-center justify-center p-6"
          >
            <motion.div 
              initial={{ scale: 0.9, y: 40 }}
              animate={{ scale: 1, y: 0 }}
              className="bg-white rounded-[40px] p-10 max-w-lg w-full relative overflow-hidden"
            >
              {/* Decorative Background */}
              <div className="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-yellow-400 via-white to-yellow-400" />
              <div className="absolute -top-24 -right-24 w-64 h-64 bg-yellow-400/10 rounded-full blur-3xl" />
              
              <button 
                onClick={() => setShowGodlyFlow(false)}
                className="absolute top-6 right-6 p-2 rounded-full bg-zinc-100 hover:bg-zinc-200 transition-colors z-10"
              >
                <X size={20} />
              </button>

              <AnimatePresence mode="wait">
                {godlyFlowStep === 0 ? (
                  <motion.div 
                    key="step-0"
                    initial={{ opacity: 0, x: 20 }}
                    animate={{ opacity: 1, x: 0 }}
                    exit={{ opacity: 0, x: -20 }}
                    className="relative z-10"
                  >
                    <div className="text-center mb-8">
                      <div className="w-20 h-20 bg-yellow-100 text-yellow-600 rounded-3xl flex items-center justify-center mx-auto mb-6 rotate-12">
                        <Crown size={48} />
                      </div>
                      <h3 className="text-4xl font-black tracking-tighter">ASCEND TO GODLY</h3>
                      <p className="text-zinc-500 mt-2">The ultimate respiratory evolution awaits.</p>
                    </div>

                    <div className="space-y-4 mb-10">
                      {[
                        { icon: <Ghost size={18} />, title: "Ethereal Void Access", desc: "Instant unlock of the rarest air tier." },
                        { icon: <Crown size={18} />, title: "Deity Badge", desc: "A permanent golden crown on your profile." },
                        { icon: <Zap size={18} />, title: "Zero Ad Policy", desc: "Complete removal of all advertisements." },
                        { icon: <ShieldCheck size={18} />, title: "Priority Sourcing", desc: "Filtered through 24k gold mesh." },
                        { icon: <Sparkles size={18} />, title: "Holographic Card", desc: "Exclusive black-and-gold card theme." }
                      ].map((feature, i) => (
                        <div key={i} className="flex items-start gap-4 p-4 bg-zinc-50 rounded-2xl border border-zinc-100">
                          <div className="mt-1 text-yellow-600">{feature.icon}</div>
                          <div>
                            <h4 className="font-bold text-sm">{feature.title}</h4>
                            <p className="text-xs text-zinc-500">{feature.desc}</p>
                          </div>
                        </div>
                      ))}
                    </div>

                    <button 
                      onClick={() => setGodlyFlowStep(1)}
                      className="w-full py-5 bg-zinc-900 text-white rounded-2xl font-black text-lg tracking-tight hover:bg-zinc-800 transition-all shadow-2xl shadow-zinc-200 flex items-center justify-center gap-2 group"
                    >
                      <span>Proceed to Ascension</span>
                      <TrendingUp size={20} className="group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
                    </button>
                  </motion.div>
                ) : (
                  <motion.div 
                    key="step-1"
                    initial={{ opacity: 0, x: 20 }}
                    animate={{ opacity: 1, x: 0 }}
                    exit={{ opacity: 0, x: -20 }}
                    className="text-center relative z-10"
                  >
                    <div className="w-24 h-24 bg-zinc-900 text-yellow-400 rounded-full flex items-center justify-center mx-auto mb-8 shadow-2xl">
                      <Zap size={48} />
                    </div>
                    <h3 className="text-3xl font-black tracking-tighter mb-4">FINAL CONFIRMATION</h3>
                    <p className="text-zinc-500 mb-8 leading-relaxed">
                      Are you sure you want to spend <span className="text-zinc-900 font-bold">$999.99</span> to transcend humanity? This action is irreversible and your lungs will never be the same.
                    </p>

                    <div className="flex flex-col gap-3">
                      <button 
                        onClick={handleUpgradeGodly}
                        className="w-full py-5 bg-yellow-400 text-yellow-950 rounded-2xl font-black text-xl tracking-tighter hover:bg-yellow-300 transition-all shadow-xl shadow-yellow-100"
                      >
                        CONFIRM ASCENSION
                      </button>
                      <button 
                        onClick={() => setGodlyFlowStep(0)}
                        className="w-full py-4 text-zinc-400 font-bold text-sm hover:text-zinc-600 transition-colors"
                      >
                        Wait, I'm not ready
                      </button>
                    </div>
                  </motion.div>
                )}
              </AnimatePresence>
            </motion.div>
          </motion.div>
        )}

        {isPurchasing && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 z-50 bg-white/80 backdrop-blur-md flex items-center justify-center p-6"
          >
            <div className="text-center">
              <motion.div 
                animate={{ rotate: 360 }}
                transition={{ duration: 1, repeat: Infinity, ease: "linear" }}
                className="w-16 h-16 border-4 border-indigo-600 border-t-transparent rounded-full mx-auto mb-6"
              />
              <h3 className="text-2xl font-black tracking-tighter">PURCHASING {selectedTier?.name.toUpperCase()}...</h3>
              <p className="text-zinc-500 mt-2">Verifying your lung capacity and credit score.</p>
            </div>
          </motion.div>
        )}

        {showSuccess && selectedTier && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 z-50 bg-zinc-900/90 backdrop-blur-xl flex items-center justify-center p-6"
          >
            <motion.div 
              initial={{ scale: 0.9, y: 20 }}
              animate={{ scale: 1, y: 0 }}
              className="bg-white rounded-[40px] p-10 max-w-xl w-full relative overflow-hidden"
            >
              <button 
                onClick={() => setShowSuccess(false)}
                className="absolute top-6 right-6 p-2 rounded-full bg-zinc-100 hover:bg-zinc-200 transition-colors"
              >
                <X size={20} />
              </button>
              
              <div className="text-center mb-10">
                <div className="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-6">
                  <ShieldCheck size={40} />
                </div>
                <h3 className="text-3xl font-black tracking-tighter">SUBSCRIPTION ACTIVE!</h3>
                <p className="text-zinc-500 mt-2">Your AirPay+ Card and DigiChip have been generated.</p>
              </div>

              <div className="flex flex-col items-center gap-8 mb-10">
                <AirPayCard tier={selectedTier} user={user} cardRef={cardRef} />
                <div className="flex items-center gap-12">
                  <DigiChip tier={selectedTier} />
                  <div className="flex flex-col items-center gap-2">
                    <div className="w-12 h-12 rounded-lg bg-zinc-100 border border-zinc-200 flex items-center justify-center">
                      <Download size={20} className="text-zinc-400" />
                    </div>
                    <span className="text-[10px] font-mono uppercase opacity-50">PNG Ready</span>
                  </div>
                </div>
              </div>

              <div className="grid grid-cols-2 gap-4">
                <button 
                  onClick={downloadCard}
                  className="flex items-center justify-center gap-2 py-4 bg-zinc-900 text-white rounded-2xl font-bold hover:bg-zinc-800 transition-all"
                >
                  <Download size={18} />
                  Download Card
                </button>
                <button 
                  onClick={() => setShowSuccess(false)}
                  className="py-4 bg-indigo-600 text-white rounded-2xl font-bold hover:bg-indigo-700 transition-all"
                >
                  Start Breathing
                </button>
              </div>
            </motion.div>
          </motion.div>
        )}

        {showPopup && (
          <PopupAd onClose={() => setShowPopup(false)} />
        )}
      </AnimatePresence>

      {/* Floating Action Button for Account */}
      <div className="fixed bottom-8 left-8 z-40">
        <button className="p-4 bg-white rounded-2xl shadow-2xl border border-zinc-200 hover:scale-110 transition-transform active:scale-95 group">
          <Bell size={24} className="text-zinc-400 group-hover:text-indigo-600 transition-colors" />
          <div className="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full border-2 border-white" />
        </button>
      </div>
    </div>
  );
}
